# NixOS Laptop .gitignore

# WireGuard private keys & configs with secrets
*.private
*.key
wg0.conf

# Hardware config (unique per machine, generated by installer)
hardware-configuration.nix

# Result symlinks from nix builds
result
result-*

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/